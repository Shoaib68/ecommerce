{
  "name": "e-market-mern",
  "version": "1.0.0",
  "description": "E-Market platform built with MERN stack",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm start --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --prefix client",
    "seed": "node server/scripts/seedDatabase.js",
    "create-admin": "node server/scripts/createAdmin.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^1.4.5-lts.1",
    "stripe": "^14.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^30.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.1"
  },
  "keywords": [
    "ecommerce",
    "mern",
    "mongodb",
    "express",
    "react",
    "nodejs"
  ],
  "author": "Your Name",
  "license": "MIT"
}
